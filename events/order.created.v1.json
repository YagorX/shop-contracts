{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shop-contracts/events/order.created.v1.json",
  "title": "OrderCreatedV1",
  "allOf": [
    {
      "$ref": "./common-envelope.v1.json"
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "const": "order.created"
        },
        "data": {
          "type": "object",
          "required": ["currency", "total_amount", "items"],
          "properties": {
            "currency": {
              "type": "string",
              "minLength": 3,
              "maxLength": 3
            },
            "total_amount": {
              "type": "number",
              "minimum": 0
            },
            "items": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["product_id", "qty", "price"],
                "properties": {
                  "product_id": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "qty": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "price": {
                    "type": "number",
                    "minimum": 0
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
