{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shop-contracts/events/common-envelope.v1.json",
  "title": "CommonEventEnvelopeV1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "order_id",
    "data"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "pattern": "^[a-z]+\\.[a-z]+$"
    },
    "event_version": {
      "type": "integer",
      "const": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "order_id": {
      "type": "string",
      "format": "uuid"
    },
    "customer_id": {
      "type": "string",
      "format": "uuid"
    },
    "data": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
